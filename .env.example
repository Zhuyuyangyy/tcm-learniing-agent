# ============================================
# tcm-ai-learning-agent 环境变量模板
# ⚠️ 复制为 .env 后填入真实密钥，切勿提交到 Git
# ============================================

# ---- 讯飞星火大模型 API 配置（核心驱动）----
# 申请地址：https://xinghuo.xfyun.cn/
SPARK_APP_ID=your_app_id_here
SPARK_API_KEY=your_api_key_here
SPARK_API_SECRET=your_api_secret_here

# 星火模型版本：generalv3.5（4.0Ultra） / generalv3（Pro） / generalv2（V2）
SPARK_API_VERSION=generalv3.5

# 星火 API 域名（一般不需要修改）
SPARK_API_URL=wss://spark-api.xinghuo.xfyun.cn/v3.5/chat

# ---- 讯飞 Embedding 配置（用于 RAG 向量化）----
SPARK_EMBEDDING_APP_ID=your_embedding_app_id_here
SPARK_EMBEDDING_API_KEY=your_embedding_api_key_here
SPARK_EMBEDDING_API_SECRET=your_embedding_api_secret_here

# ---- 向量数据库 ----
CHROMA_PERSIST_DIR=./data/vector_db
CHROMA_COLLECTION_NAME=tcm_knowledge

# ---- 中医知识图谱 ----
TCM_GRAPH_PATH=./data/knowledge_base/知识图谱

# ---- FastAPI 服务配置 ----
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ---- 日志 ----
LOG_LEVEL=INFO
